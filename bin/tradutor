#!/bin/fish
set mode "online"
set clearMode "off"
for arg in  "$argv"
    switch "$arg"
        case "--offline"
            set mode "offline"
        case "--online"
            set mode "online"
        case "--clearOn" "--con"
            set clearMode "on"
        case "--help" "-h"
            echo -e " --offline -> desativa a pesquisa via internet\n --clearOn ou --con -> ativa o clearMode\n\n ***DENTRO DO TRADUTOR***\n\n clearOn -> ativa o clearMode\n clearOff -> desativa o clearMode\n offline -> desativa a pesquisa via internet\n online -> ativa a pesquisa na internet\n dict -> abre o dicionário"
            exit
        case *
            echo "Opção inválida: $1"
            exit
    end
end

while true
    echo "««WORD»»"
    echo ""
    read word
    echo ""
    switch $word 
        case "clear"
            clear
            continue
        case "offline"
            set mode "offline"
            if test "$clearMode" = "on"
                clear
            end
            continue
        case "online"
            set mode "online"
            if test "$clearMode" = "on"
                clear
            end
            continue
        case "clearOn" "clearon"
            set clearMode "on"
            if test "$clearMode" = "on"
                clear
            end
            continue
        case "clearOff" "clearoff"
            set clearMode "off"
            continue
        case "help"
            echo -e " --offline -> desativa a pesquisa via internet\n --clearOn ou --con -> ativa o clearMode\n\n ***DENTRO DO TRADUTOR***\n\n clearOn -> ativa o clearMode\n clearOff -> desativa o clearMode\n offline -> desativa a pesquisa via internet\n online -> ativa a pesquisa na internet\n dict -> abre o dicionário\n"
            echo "***PRESS ANY BUTTON TO CONTINUE***"
            read button
            if test "$clearMode" = "on"
                clear
            end
            continue
        case "change"
            exit 0
        case "clip"
            exit 1
    end
    echo "««TRADUCTION»»"
    echo ""
    if test "$mode" = "online"
        trans -e google :pt "$word"
            echo ""
    else if test "$mode" = "offline"
        trans.py $word
        echo ""
    end
    if test "$clearMode" = "on"
        echo "««WAITING»»"
        read palavra
        clear
    end
end

