#!/bin/fish
set mode "pt"
while true
    if test "$mode" = "pt"
        tradutor
        switch "$status"
            case 0
                set mode "en"
            case 1
                set mode "clip"
        end
    else if test "$mode" = "en"
        translate 
        switch "$status"
            case 0
                set mode "pt"
            case 1
                set mode "clip"
        end
    else if test "$mode" = "clip"
        clip-trans
        switch "$status"
            case 0
                set mode "pt"
        end
    else
        echo "invalid argument: $mode"
        read mode
    end
end
