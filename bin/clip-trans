#!/bin/fish
set clip2 ""
set i 0
while true
    sleep 1
    set clip1 (wl-paste)
    if test "$clip1" = "cancel"
        exit 0
    else if test "$clip1" != "$clip2"
        set i (math $i+1)
        clear
        echo "cancel"
        trans -e google :pt "$clip1"
        set clip2 (wl-paste)
    end
end


