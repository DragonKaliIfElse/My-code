#!/bin/fish
set prompt false
for arg in $argv
    switch $arg
        case "--prompt"
            set prompt true
    end
end
if test "$prompt" == true
    ssh -D 1080 ubuntu@146.235.52.41 -i /home/4n4tm4n/.ssh/ssh-key-proxy.key
else
    ssh -D 1080 -f -N ubuntu@146.235.52.41 -i /home/4n4tm4n/.ssh/ssh-key-proxy.key
end
