#!/bin/fish
set clear false
for arg in $argv
    switch $arg
        case "--clearOn"
            set clear true
    end
end
while true
    if test "$clear" = true
        clear
    end
	read -P "Palavra para traduzir para o inglês: " input
    echo ""
    switch "$input"
        case "change"
            clear
            exit 0
        case "clip"
            clear 
            exit 1
        case "clear"
            clear
            continue
        case "clearOn"
            set clear true
            clear
            continue
        case "clearOff"
            set clear false
            continue
    end
	trans :en "$input"
    if test "$clearOn" = "on"
        echo "««WAITING»»"
        read nothing
        clear
    end
end
